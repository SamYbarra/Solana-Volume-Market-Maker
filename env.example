# Solana RPC Configuration
RPC_URL=https://api.mainnet-beta.solana.com
RPC_URL_DEVNET=https://api.devnet.solana.com
USE_DEVNET=false

# Wallet Configuration (comma-separated private keys)
# Format: WALLET_1_PRIVATE_KEY,WALLET_2_PRIVATE_KEY,WALLET_3_PRIVATE_KEY
# Private keys can be in base58 or hex format
WALLET_PRIVATE_KEYS=your_private_key_1,your_private_key_2,your_private_key_3

# Trading Configuration
MIN_BUY_AMOUNT_SOL=0.1
MAX_BUY_AMOUNT_SOL=1.0
MIN_SELL_AMOUNT_SOL=0.1
MAX_SELL_AMOUNT_SOL=1.0

# Market Cap Limits
MIN_MARKET_CAP_SOL=1000
MAX_MARKET_CAP_SOL=100000

# Trading Behavior (to act like real traders)
MIN_TRADE_DELAY_SECONDS=5
MAX_TRADE_DELAY_SECONDS=30
RANDOMIZE_TRADE_SIZE=true
RANDOMIZE_TRADE_TIMING=true

# Pumpfun Token Configuration
TOKEN_ADDRESS=your_token_address_here

# Chart Configuration
CHART_UPDATE_INTERVAL_SECONDS=60
CHART_OUTPUT_DIR=charts

# Bot Control
ENABLE_BUY=true
ENABLE_SELL=true
TRADING_ENABLED=true

# Health Check
HEALTH_CHECK_INTERVAL_SECONDS=300
