  "description": "Automated Pumpfun market maker bot for Solana",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsc --watch",
    "dev:run": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
