    "dotenv": "^16.3.1",
    "chart.js": "^4.4.0",
    "chartjs-node-canvas": "^4.1.6",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/bs58": "^5.0.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  }
